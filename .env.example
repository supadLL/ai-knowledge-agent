# Optional model/provider settings for future LLM-backed generation.
AI_KNOWLEDGE_AGENT_DATA_DIR=./data
AI_KNOWLEDGE_AGENT_TOP_K=5
AI_KNOWLEDGE_AGENT_CHUNK_SIZE=900
AI_KNOWLEDGE_AGENT_CHUNK_OVERLAP=120
AI_KNOWLEDGE_AGENT_VECTOR_WEIGHT=0.65

# Default local provider. Use "openai-compatible" to call /embeddings.
AI_KNOWLEDGE_AGENT_EMBEDDING_PROVIDER=hash
AI_KNOWLEDGE_AGENT_EMBEDDING_DIMENSIONS=256
AI_KNOWLEDGE_AGENT_EMBEDDING_MODEL=text-embedding-3-small
AI_KNOWLEDGE_AGENT_EMBEDDING_BASE_URL=https://api.openai.com/v1
# AI_KNOWLEDGE_AGENT_EMBEDDING_API_KEY=

# Default generation is local extractive. Use "openai-compatible" for chat completions.
AI_KNOWLEDGE_AGENT_GENERATION_PROVIDER=local
AI_KNOWLEDGE_AGENT_GENERATION_MODEL=gpt-4o-mini
AI_KNOWLEDGE_AGENT_GENERATION_BASE_URL=https://api.openai.com/v1
AI_KNOWLEDGE_AGENT_GENERATION_CONTEXT_CHARS=6000
# AI_KNOWLEDGE_AGENT_GENERATION_API_KEY=
